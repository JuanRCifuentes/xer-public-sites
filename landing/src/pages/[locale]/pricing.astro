---
import { locales } from "../../utils/i18n";
import type { Locale } from "../../utils/i18n";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const { pricingLabels: labels, tiers, featureSections, faqs } =
	await import(`../../data/${locale}/pricing.ts`);

const tierKeys = ["starter", "scale", "growth"] as const;
---

<BaseLayout title={labels.title} description={labels.subtitle} locale={locale}>
	<script slot="head" type="application/ld+json" set:html={JSON.stringify([
		{
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "Home", "item": new URL(`/${locale}/`, Astro.site).href },
				{ "@type": "ListItem", "position": 2, "name": labels.title },
			],
		},
	])} />

	<!-- Pricing section -->
	<form class="group/tiers isolate overflow-hidden">
		<div class="flow-root border-b border-b-transparent bg-gray-900 pt-24 pb-16 sm:pt-32 lg:pb-0 dark:border-b-white/5 dark:bg-gray-800/25">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="relative z-10">
					<h2 class="mx-auto max-w-4xl text-center text-5xl font-semibold tracking-tight text-balance text-white sm:text-6xl">{labels.title}</h2>
					<p class="mx-auto mt-6 max-w-2xl text-center text-lg font-medium text-pretty text-gray-400 sm:text-xl/8">{labels.subtitle}</p>
					<div class="mt-16 flex justify-center">
						<fieldset aria-label="Payment frequency">
							<div class="grid grid-cols-2 gap-x-1 rounded-full bg-white/5 p-1 text-center text-xs/5 font-semibold text-white">
								<label class="group relative rounded-full px-2.5 py-1 has-checked:bg-indigo-500">
									<input type="radio" name="frequency" value="monthly" checked class="absolute inset-0 appearance-none rounded-full" />
									<span class="text-white">{labels.monthly}</span>
								</label>
								<label class="group relative rounded-full px-2.5 py-1 has-checked:bg-indigo-500">
									<input type="radio" name="frequency" value="annually" class="absolute inset-0 appearance-none rounded-full" />
									<span class="text-white">{labels.annually}</span>
								</label>
							</div>
						</fieldset>
					</div>
				</div>
				<div class="relative mx-auto mt-10 grid max-w-md grid-cols-1 gap-y-8 lg:mx-0 lg:-mb-14 lg:max-w-none lg:grid-cols-3">
					<svg viewBox="0 0 1208 1024" aria-hidden="true" class="absolute -bottom-48 left-1/2 h-256 -translate-x-1/2 translate-y-1/2 mask-[radial-gradient(closest-side,white,transparent)] lg:-top-48 lg:bottom-auto lg:translate-y-0">
						<ellipse cx="604" cy="512" rx="604" ry="512" fill="url(#pricing-gradient)" />
						<defs>
							<radialGradient id="pricing-gradient">
								<stop stop-color="#7775D6" />
								<stop offset="1" stop-color="#E935C1" />
							</radialGradient>
						</defs>
					</svg>
					<div aria-hidden="true" class="hidden lg:absolute lg:inset-x-px lg:top-4 lg:bottom-0 lg:block lg:rounded-t-2xl lg:bg-gray-800/80 lg:ring-1 lg:ring-white/10"></div>
					{tiers.map((tier: any) => (
						<div data-featured={tier.featured ? "true" : undefined} class:list={[
							"group/tier relative rounded-2xl",
							tier.featured
								? "z-10 bg-white shadow-xl outline-1 outline-gray-900/10 dark:bg-gray-800 dark:shadow-none dark:-outline-offset-1 dark:outline-white/10"
								: "bg-gray-800/80 outline-1 -outline-offset-1 outline-white/10 lg:bg-transparent lg:pb-14 lg:outline-0",
						]}>
							<div class="p-8 lg:pt-12 xl:p-10 xl:pt-14">
								<h3 id={tier.id} class="text-sm/6 font-semibold text-white group-data-featured/tier:text-gray-900 dark:group-data-featured/tier:text-white">{tier.name}</h3>
								<div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between lg:flex-col lg:items-stretch">
									<div class="mt-2 flex items-center gap-x-4">
										<p class="text-4xl font-semibold tracking-tight text-white group-not-has-[[name=frequency][value=monthly]:checked]/tiers:hidden group-data-featured/tier:text-gray-900 dark:group-data-featured/tier:text-white">{tier.monthlyPrice}</p>
										<p class="text-4xl font-semibold tracking-tight text-white group-not-has-[[name=frequency][value=annually]:checked]/tiers:hidden group-data-featured/tier:text-gray-900 dark:group-data-featured/tier:text-white">{tier.annualPrice}</p>
										<div class="text-sm">
											<p class="text-white group-data-featured/tier:text-gray-900 dark:group-data-featured/tier:text-white">{labels.currency}</p>
											<p class="text-gray-400 group-not-has-[[name=frequency][value=monthly]:checked]/tiers:hidden group-data-featured/tier:text-gray-500 dark:group-data-featured/tier:text-gray-400">{labels.billedMonthly}</p>
											<p class="text-gray-400 group-not-has-[[name=frequency][value=annually]:checked]/tiers:hidden group-data-featured/tier:text-gray-500 dark:group-data-featured/tier:text-gray-400">{labels.billedAnnually}</p>
										</div>
									</div>
									<button type="submit" name="tier" value={tier.name.toLowerCase()} aria-describedby={tier.id} class="w-full rounded-md bg-white/10 px-3 py-2 text-center text-sm/6 font-semibold text-white not-group-data-featured:inset-ring not-group-data-featured:inset-ring-white/5 group-data-featured/tier:bg-indigo-600 group-data-featured/tier:shadow-xs hover:bg-white/20 group-data-featured/tier:hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/75 group-data-featured/tier:focus-visible:outline-indigo-600 dark:group-data-featured/tier:bg-indigo-500 dark:group-data-featured/tier:shadow-none dark:group-data-featured/tier:hover:bg-indigo-400 dark:group-data-featured/tier:focus-visible:outline-indigo-500">{labels.buyButton}</button>
								</div>
								<div class="mt-8 flow-root sm:mt-10">
									<ul role="list" class="-my-2 divide-y divide-white/5 border-t border-white/5 text-sm/6 text-white group-data-featured/tier:divide-gray-900/5 group-data-featured/tier:border-gray-900/5 group-data-featured/tier:text-gray-600 lg:border-t-0 dark:group-data-featured/tier:divide-white/10 dark:group-data-featured/tier:border-white/10 dark:group-data-featured/tier:text-white">
										{tier.highlights.map((feature: string) => (
											<li class="flex gap-x-3 py-2">
												<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-6 w-5 flex-none text-gray-500 group-data-featured/tier:text-indigo-600 dark:group-data-featured/tier:text-indigo-400">
													<path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" />
												</svg>
												{feature}
											</li>
										))}
									</ul>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
		<div class="relative bg-gray-50 lg:pt-14 dark:bg-gray-900">
			<div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
				<!-- Feature comparison (up to lg) -->
				<section aria-labelledby="mobile-comparison-heading" class="lg:hidden">
					<h2 id="mobile-comparison-heading" class="sr-only">{labels.featureComparison}</h2>
					<div class="mx-auto max-w-2xl space-y-16">
						{tiers.map((tier: any) => {
							const tierKey = tier.name.toLowerCase() as "starter" | "scale" | "growth";
							return (
								<div class="border-t border-gray-900/10 dark:border-white/10">
									<div class:list={["-mt-px w-72 border-t-2 pt-10 md:w-80", tier.featured ? "border-indigo-600 dark:border-indigo-500" : "border-transparent"]}>
										<h3 class:list={["text-sm/6 font-semibold", tier.featured ? "text-indigo-600 dark:text-indigo-400" : "text-gray-900 dark:text-white"]}>{tier.name}</h3>
										<p class="mt-1 text-sm/6 text-gray-600 dark:text-gray-400">{tier.description}</p>
									</div>
									<div class="mt-10 space-y-10">
										{featureSections.map((section: any) => (
											<div>
												<h4 class="text-sm/6 font-semibold text-gray-900 dark:text-white">{section.name}</h4>
												<div class="relative mt-6">
													<div aria-hidden="true" class="absolute inset-y-0 right-0 hidden w-1/2 rounded-lg bg-white shadow-xs sm:block dark:bg-gray-800/50 dark:shadow-none"></div>
													<div class:list={[
														"relative rounded-lg bg-white shadow-xs sm:rounded-none sm:bg-transparent sm:shadow-none sm:ring-0 dark:bg-gray-800/50 dark:shadow-none dark:sm:bg-transparent",
														tier.featured ? "ring-2 ring-indigo-600 dark:ring-indigo-500" : "ring-1 ring-gray-900/10 dark:ring-white/10",
													]}>
														<dl class="divide-y divide-gray-200 text-sm/6 dark:divide-white/10">
															{section.features.map((feature: any) => {
																const value = feature[tierKey];
																return (
																	<div class="flex items-center justify-between px-4 py-3 sm:grid sm:grid-cols-2 sm:px-0">
																		<dt class="pr-4 text-gray-600 dark:text-gray-400">{feature.name}</dt>
																		<dd class="flex items-center justify-end sm:justify-center sm:px-4">
																			{value === true ? (
																				<>
																					<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mx-auto size-5 text-indigo-600 dark:text-indigo-400">
																						<path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" />
																					</svg>
																					<span class="sr-only">Yes</span>
																				</>
																			) : value === false ? (
																				<>
																					<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mx-auto size-5 text-gray-400 dark:text-gray-600">
																						<path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
																					</svg>
																					<span class="sr-only">No</span>
																				</>
																			) : (
																				<span class:list={[tier.featured ? "font-semibold text-indigo-600 dark:text-indigo-400" : "text-gray-900 dark:text-white"]}>{value}</span>
																			)}
																		</dd>
																	</div>
																);
															})}
														</dl>
													</div>
													<div aria-hidden="true" class:list={[
														"pointer-events-none absolute inset-y-0 right-0 hidden sm:block w-1/2 rounded-lg",
														tier.featured ? "ring-2 ring-indigo-600 dark:ring-indigo-500" : "ring-1 ring-gray-900/10 dark:ring-white/10",
													]}></div>
												</div>
											</div>
										))}
									</div>
								</div>
							);
						})}
					</div>
				</section>

				<!-- Feature comparison (lg+) -->
				<section aria-labelledby="comparison-heading" class="hidden lg:block">
					<h2 id="comparison-heading" class="sr-only">{labels.featureComparison}</h2>

					<div class="grid grid-cols-4 gap-x-8 border-t border-gray-900/10 before:block dark:border-white/10">
						{tiers.map((tier: any) => (
							<div aria-hidden="true" class="-mt-px">
								<div class:list={["border-t-2 pt-10", tier.featured ? "border-indigo-600 dark:border-indigo-500" : "border-transparent"]}>
									<p class:list={["text-sm/6 font-semibold", tier.featured ? "text-indigo-600 dark:text-indigo-400" : "text-gray-900 dark:text-white"]}>{tier.name}</p>
									<p class="mt-1 text-sm/6 text-gray-600 dark:text-gray-400">{tier.description}</p>
								</div>
							</div>
						))}
					</div>

					<div class="-mt-6 space-y-16">
						{featureSections.map((section: any) => (
							<div>
								<h3 class="text-sm/6 font-semibold text-gray-900 dark:text-white">{section.name}</h3>
								<div class="relative -mx-8 mt-10">
									<div aria-hidden="true" class="absolute inset-x-8 inset-y-0 grid grid-cols-4 gap-x-8 before:block">
										<div class="size-full rounded-lg bg-white shadow-xs dark:bg-gray-800/50 dark:shadow-none"></div>
										<div class="size-full rounded-lg bg-white shadow-xs dark:bg-gray-800/50 dark:shadow-none"></div>
										<div class="size-full rounded-lg bg-white shadow-xs dark:bg-gray-800/50 dark:shadow-none"></div>
									</div>

									<table class="relative w-full border-separate border-spacing-x-8">
										<thead>
											<tr class="text-left">
												<th scope="col"><span class="sr-only">Feature</span></th>
											</tr>
										</thead>
										<tbody>
											{section.features.map((feature: any, featureIdx: number) => (
												<tr>
													<th scope="row" class="w-1/4 py-3 pr-4 text-left text-sm/6 font-normal text-gray-900 dark:text-white">
														{feature.name}
														{featureIdx < section.features.length - 1 && (
															<div class="absolute inset-x-8 mt-3 h-px bg-gray-200 dark:bg-white/10"></div>
														)}
													</th>
													{tierKeys.map((key) => {
														const value = feature[key];
														return (
															<td class="relative w-1/4 px-4 py-0 text-center">
																<span class="relative size-full py-3">
																	{value === true ? (
																		<>
																			<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mx-auto size-5 text-indigo-600 dark:text-indigo-400">
																				<path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" />
																			</svg>
																			<span class="sr-only">Yes</span>
																		</>
																	) : value === false ? (
																		<>
																			<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mx-auto size-5 text-gray-400 dark:text-gray-600">
																				<path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
																			</svg>
																			<span class="sr-only">No</span>
																		</>
																	) : (
																		<span class:list={[
																			"text-sm/6",
																			tiers.find((t: any) => t.name.toLowerCase() === key)?.featured
																				? "font-semibold text-indigo-600 dark:text-indigo-400"
																				: "text-gray-900 dark:text-white",
																		]}>{value}</span>
																	)}
																</span>
															</td>
														);
													})}
												</tr>
											))}
										</tbody>
									</table>

									<div aria-hidden="true" class="pointer-events-none absolute inset-x-8 inset-y-0 grid grid-cols-4 gap-x-8 before:block">
										<div class="rounded-lg ring-1 ring-gray-900/10 dark:ring-white/10"></div>
										<div class="rounded-lg ring-2 ring-indigo-600 dark:ring-indigo-500"></div>
										<div class="rounded-lg ring-1 ring-gray-900/10 dark:ring-white/10"></div>
									</div>
								</div>
							</div>
						))}
					</div>
				</section>
			</div>
		</div>
	</form>

	<!-- FAQ section -->
	<div class="mx-auto mt-24 max-w-7xl px-6 sm:mt-56 lg:px-8">
		<h2 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl dark:text-white">{labels.faqTitle}</h2>
		<dl class="mt-20 divide-y divide-gray-900/10 dark:divide-white/10">
			{faqs.map((faq: any) => (
				<div class="py-8 first:pt-0 last:pb-0 lg:grid lg:grid-cols-12 lg:gap-8">
					<dt class="text-base/7 font-semibold text-gray-900 lg:col-span-5 dark:text-white">{faq.question}</dt>
					<dd class="mt-4 lg:col-span-7 lg:mt-0">
						<p class="text-base/7 text-gray-600 dark:text-gray-400">{faq.answer}</p>
					</dd>
				</div>
			))}
		</dl>
	</div>

	<!-- Bottom spacer -->
	<div class="pb-24 sm:pb-56"></div>
</BaseLayout>
