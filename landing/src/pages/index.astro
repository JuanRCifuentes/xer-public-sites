---
import { hero, logoCloud, featureCards, featureGrid, stats, cta } from "../data/home";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import LogoCloud from "../components/LogoCloud.astro";
import FeatureCards from "../components/FeatureCards.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import StatsSection from "../components/StatsSection.astro";
import CtaSection from "../components/CtaSection.astro";
---

<BaseLayout title="Astro">
	<HeroSection {...hero} />
	<LogoCloud {...logoCloud} />
	<FeatureCards {...featureCards} />
	<FeatureGrid {...featureGrid} />
	<StatsSection {...stats} />
	<CtaSection {...cta} />
</BaseLayout>
