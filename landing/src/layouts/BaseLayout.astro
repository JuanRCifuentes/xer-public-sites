---
import "../styles.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { locales, getLocalePath } from "../utils/i18n";
import type { Locale } from "../utils/i18n";

interface Props {
  title: string;
  description?: string;
  image?: string;
  locale: Locale;
  type?: "website" | "article";
  publishedTime?: string;
  author?: string;
}

const { title, description, image, locale, type = "website", publishedTime, author } = Astro.props;

const siteName = "Xer";
const fullTitle = `${title} | ${siteName}`;

const { header, footer } = locale === "es"
  ? await import("../data/es/layout")
  : await import("../data/en/layout");

const currentPath = Astro.url.pathname.replace(`/${locale}`, "") || "/";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="https://xer-assets.juanrcifuentes.com/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#4f46e5" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#1f2937" media="(prefers-color-scheme: dark)" />
		<title>{fullTitle}</title>
		{description && <meta name="description" content={description} />}
		<link rel="canonical" href={canonicalUrl.href} />
		{locales.map((loc) => (
			<link rel="alternate" hreflang={loc} href={new URL(getLocalePath(loc, currentPath), Astro.site).href} />
		))}
		<link rel="alternate" hreflang="x-default" href={new URL(getLocalePath("en", currentPath), Astro.site).href} />
		<link rel="preconnect" href="https://tailwindcss.com" />
		<link rel="preconnect" href="https://images.unsplash.com" />
		<link rel="preconnect" href="https://xer-assets.juanrcifuentes.com" />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl.href} />
		<meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
		{locales.filter(loc => loc !== locale).map((loc) => (
			<meta property="og:locale:alternate" content={loc === "es" ? "es_ES" : "en_US"} />
		))}
		{image && <meta property="og:image" content={image} />}
		{type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{type === "article" && author && <meta property="article:author" content={author} />}
		<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		{image && <meta name="twitter:image" content={image} />}
		<slot name="head" />
		<script src="@tailwindplus/elements"></script>
	</head>
	<body>
		<div class="bg-white dark:bg-gray-900">
			<Navigation {...header} locale={locale} />
			<main>
				<slot />
			</main>
			<Footer {...footer} />
		</div>
	</body>
</html>
