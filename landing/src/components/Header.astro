---
import { locales, localeNames, getLocalePath } from "../utils/i18n";
import type { Locale } from "../utils/i18n";

interface Props {
  logo: { light: string; dark: string; alt: string };
  navLinks: Array<{ text: string; href: string }>;
  loginLink: { text: string; href: string };
  locale: Locale;
}

const { logo, navLinks, loginLink, locale } = Astro.props;
---

<header class="sticky top-0 z-50 bg-white/75 shadow-[0_1px_3px_0_rgba(0,0,0,0.05)] ring-1 ring-gray-900/5 backdrop-blur-md dark:bg-gray-900/75 dark:shadow-none dark:ring-white/10">
  <nav aria-label="Global" class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8">
    <div class="flex items-center gap-x-12">
      <a href="#" class="-m-1.5 p-1.5">
        <span class="sr-only">{logo.alt}</span>
        <img src={logo.light} alt="" class="h-8 w-auto dark:hidden" />
        <img src={logo.dark} alt="" class="h-8 w-auto not-dark:hidden" />
      </a>
      <div class="hidden lg:flex lg:gap-x-12">
        {navLinks.map((link) => (
          <a href={link.href} class="text-sm/6 font-semibold text-gray-900 dark:text-white">{link.text}</a>
        ))}
      </div>
    </div>
    <div class="flex lg:hidden">
      <button type="button" command="show-modal" commandfor="mobile-menu" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 dark:text-gray-400 dark:hover:text-white">
        <span class="sr-only">Open main menu</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:items-center lg:gap-x-6">
      <div class="relative flex items-center">
        <button popovertarget="lang-menu" class="inline-flex items-center gap-x-1 text-sm/6 font-semibold text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
            <path d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
        </button>
        <el-popover id="lang-menu" anchor="bottom" popover class="w-screen max-w-min overflow-visible bg-transparent px-4 transition transition-discrete [--anchor-gap:--spacing(5)] backdrop:bg-transparent open:flex data-closed:translate-y-1 data-closed:opacity-0 data-enter:duration-200 data-enter:ease-out data-leave:duration-150 data-leave:ease-in">
          <div class="w-40 shrink rounded-xl bg-white p-4 text-sm/6 font-semibold text-gray-900 shadow-lg outline-1 outline-gray-900/5 dark:bg-gray-800 dark:text-white dark:shadow-none dark:outline dark:-outline-offset-1 dark:outline-white/10">
            {locales.map((loc) => (
              <a href={getLocalePath(loc, "/")} class:list={["block rounded-md p-2 hover:text-indigo-600 dark:hover:text-indigo-400", loc === locale && "text-indigo-600 dark:text-indigo-400"]}>{localeNames[loc]}</a>
            ))}
          </div>
        </el-popover>
      </div>
      <a href={loginLink.href} class="text-sm/6 font-semibold text-gray-900 dark:text-white">{loginLink.text} <span aria-hidden="true">&rarr;</span></a>
    </div>
  </nav>
  <el-dialog>
    <dialog id="mobile-menu" class="backdrop:bg-transparent lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline-none">
        <el-dialog-panel class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white p-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10 dark:bg-gray-900 dark:sm:ring-gray-100/10">
          <div class="flex items-center justify-between">
            <a href="#" class="-m-1.5 p-1.5">
              <span class="sr-only">{logo.alt}</span>
              <img src={logo.light} alt="" class="h-8 w-auto dark:hidden" />
              <img src={logo.dark} alt="" class="h-8 w-auto not-dark:hidden" />
            </a>
            <button type="button" command="close" commandfor="mobile-menu" class="-m-2.5 rounded-md p-2.5 text-gray-700 dark:text-gray-400 dark:hover:text-white">
              <span class="sr-only">Close menu</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
          <div class="mt-6 flow-root">
            <div class="-my-6 divide-y divide-gray-500/10 dark:divide-white/10">
              <div class="space-y-2 py-6">
                {navLinks.map((link) => (
                  <a href={link.href} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5">{link.text}</a>
                ))}
              </div>
              <div class="space-y-2 py-6">
                {locales.map((loc) => (
                  <a href={getLocalePath(loc, "/")} class:list={["-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5", loc === locale && "text-indigo-600 dark:text-indigo-400"]}>{localeNames[loc]}</a>
                ))}
              </div>
              <div class="py-6">
                <a href={loginLink.href} class="-mx-3 block rounded-lg px-3 py-2.5 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5">{loginLink.text}</a>
              </div>
            </div>
          </div>
        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>
